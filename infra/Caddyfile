# SuperParty — Caddy Configuration
# Reverse proxy + HTTPS + Rate Limiting + Security Headers
#
# USAGE:
#   1. Înlocuiește {$DOMAIN} cu domeniul tău (ex: api.superparty.ro)
#      sau setează env var DOMAIN=api.superparty.ro
#   2. Dacă nu ai domeniu, folosește IP-ul direct cu TLS intern:
#      Comentează linia {$DOMAIN} și decomentează linia :443
#
# INSTALL: sudo cp Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy

{
	# Global options
	email admin@superparty.ro
	
	# Rate limiting — necesită plugin caddy-ratelimit
	# Instalare: xcaddy build --with github.com/mholt/caddy-ratelimit
	order rate_limit before basicauth
}

# ─── Main API ───────────────────────────────────────────────
{$DOMAIN:api.superparty.ro} {
	# HTTPS automat via Let's Encrypt

	# ── Security Headers ──
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "1; mode=block"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' wss: https:; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none'"
		-Server
	}

	# ── Rate Limiting (API routes) ──
	# 100 requests/min per IP pe rute API
	rate_limit {
		zone api_zone {
			key {remote_host}
			events 100
			window 1m
		}
		match {
			path /api/*
		}
	}

	# ── Reverse Proxy → Backend Node ──
	reverse_proxy localhost:3001 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# Health check
		health_uri /status
		health_interval 30s
		health_timeout 5s
	}

	# ── Access Logging ──
	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 10
		}
		format json
	}
}

# ─── Grafana (protejat cu basicauth) ────────────────────────
# Accesibil doar prin Caddy, cu autentificare
{$DOMAIN:api.superparty.ro}:443/grafana/* {
	# Basic Auth — generează hash: caddy hash-password
	basicauth {
		{$GRAFANA_USER:admin} {$GRAFANA_HASH:JDJhJDE0JDVSd1l4bnFGRjF6N0xhYVdxWjJqaE9BbTBSdHlLbGIvQ1RqLnJtOW5HMkFRY0F6cGJD}
	}
	
	uri strip_prefix /grafana
	reverse_proxy localhost:3000
}

# ─── Prometheus / Loki — NU expuse public ───────────────────
# Accesibile DOAR de pe localhost (docker network)
# Dacă ai nevoie de acces remote, folosește SSH tunnel:
#   ssh -L 9090:localhost:9090 user@server
