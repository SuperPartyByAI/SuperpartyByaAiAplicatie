# Superparty AI Manager — Environment Variables
#
# USAGE:
#   1. cp .env.example .env
#   2. Completează valorile reale
#   3. NU comite .env în git!
#
# Pe server: /opt/superparty-ai/config/.env

# ─── Server ────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production
AI_ADMIN_TOKEN=replace-with-secure-random-token

# ─── Supabase (același proiect ca prod, tabele noi) ────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace-with-your-key
OPENAI_MODEL=gpt-4o-mini

# ─── Redis (același Redis ca voice/outbox) ─────────────────────
REDIS_URL=redis://localhost:6379

# ─── Observability ─────────────────────────────────────────────
LOG_LEVEL=info

# ─── AI Policy ─────────────────────────────────────────────────
AI_MAX_CONFIDENCE_AUTO_APPROVE=0.95
AI_ESCALATE_THRESHOLD=0.50

# ─── GPS / Geofences ───────────────────────────────────────────
GEOFENCE_SEDIU_LAT=44.4268
GEOFENCE_SEDIU_LNG=26.1025
GEOFENCE_SEDIU_RADIUS_M=200

# ─── Batch Analysis ────────────────────────────────────────────
ANALYSIS_CONCURRENCY=2
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=/opt/superparty-ai/config/gdrive-sa.json
