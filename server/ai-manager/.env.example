# =============================================================
# AI Manager — Environment Variables
# =============================================================
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# =============================================================

# --- Server ---
PORT=3002
NODE_ENV=production
LOG_LEVEL=info

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Auth (required) ---
AI_ADMIN_TOKEN=change-me-to-a-long-random-token

# --- AI Provider (local-first by default) ---
# Options: 'local' (default, uses Ollama) | 'openai'
AI_PROVIDER=local

# Local LLM via Ollama (recommended for CPU servers)
# Install: curl -fsSL https://ollama.ai/install.sh | sh
# Pull model: ollama pull llama3.2:1b
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:1b

# Local vision (optional, for batch image/video analysis)
LOCAL_VISION_URL=

# Fallback provider if local fails: 'none' (default) | 'openai'
FALLBACK_PROVIDER=none

# --- OpenAI (optional — only needed if AI_PROVIDER=openai or FALLBACK_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Redis (required for BullMQ workers) ---
REDIS_URL=redis://ai-redis:6379

# --- GPS / Geofence (optional) ---
HQ_LAT=44.4268
HQ_LNG=26.1025
HQ_RADIUS_METERS=200

# --- Policy tuning (optional) ---
AI_MAX_CONFIDENCE_AUTO_APPROVE=0.95
AI_ESCALATE_THRESHOLD=0.50

# --- Processing (optional) ---
ANALYSIS_CONCURRENCY=2
