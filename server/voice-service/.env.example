PORT=3001
## IMPORTANT:
## PUBLIC_URL must match EXACTLY the base URL configured in Twilio Console for Voice webhooks
## (used for X-Twilio-Signature validation).
## BASE_URL is used to build callback URLs Twilio must reach (/dial-status, /join-conference).
PUBLIC_URL=https://voice.superparty.ro  # ⚠️ TREBUIE să fie domeniul HTTPS real, nu IP intern!
BASE_URL=https://voice.yourdomain.com
NODE_ENV=production
LOG_LEVEL=info

# Supabase credentials
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY
JWT_SECRET=REQUIRED_random_32+_chars_for_ws_auth

# Twilio Access & Keys
# ⚠️  IMPORTANT: variabila CORECTĂ este TWILIO_AUTH_TOKEN, NU TWILIO_TOKEN
# Dacă scrii TWILIO_TOKEN, codul returnează twilio_not_configured și Twilio
# redă automat un mesaj audio de eroare ("we are sorry...").
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=your_api_key_secret

# Twilio Voice / Call Flow
# ⚠️  IMPORTANT: variabila CORECTĂ este TWIML_APP_SID, NU TWILIO_TWIML_APP_SID
TWIML_APP_SID=AP...
TWILIO_PUSH_CREDENTIAL_SID=CR...
TWILIO_PHONE_NUMBER=+40...
TWILIO_CALLER_ID=+40...

# Token special intern
ADMIN_TOKEN=your_admin_secret
