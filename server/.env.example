# SuperParty Backend — Environment Variables
# 
# USAGE:
#   1. Copiază acest fișier: cp .env.example .env
#   2. Completează valorile reale
#   3. NU comite .env în git!
#
# Pe server: /opt/superparty/.env

# ─── Backend ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
ADMIN_TOKEN=your-secure-admin-token-here

# ─── Firebase ─────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/opt/superparty/serviceAccountKey.json
FIREBASE_PROJECT_ID=superparty-frontend

# ─── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_CALLER_ID=+40xxxxxxxxxx
PUBLIC_URL=https://api.superparty.ro

# ─── Observability ────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/opt/superparty/logs

# ─── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-this-strong-password
GRAFANA_USER=admin
# Hash-ul parolei pentru Caddy basicauth (generat cu: caddy hash-password)
GRAFANA_HASH=your-caddy-bcrypt-hash

# ─── Domain ───────────────────────────────────────────────────
DOMAIN=api.superparty.ro

# ─── CI/CD (GitHub Actions Secrets) ──────────────────────────
# Acestea se setează în GitHub Settings > Secrets, NU aici:
# SSH_PRIVATE_KEY=...
# DEPLOY_HOST=46.225.182.127
# DEPLOY_USER=superparty
# DEPLOY_PATH=/opt/superparty/current
# FIREBASE_SERVICE_ACCOUNT=... (JSON)
