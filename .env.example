# ============================================================
# Superparty V6 — Environment Variables Template
# NEVER commit the real .env — only this .env.example
# Copy: cp .env.example .env  then fill in values from password manager
# ============================================================

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Twilio Voice ────────────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CALLER_ID=+40xxxxxxxxx
TWILIO_PHONE_NUMBER=+40xxxxxxxxx

# ── Public URLs ─────────────────────────────────────────────
PUBLIC_URL=https://voice.superparty.ro
WHATSAPP_API_URL=http://localhost:3001

# ── WA Internal Token (worker ↔ server) ─────────────────────
# Generate: openssl rand -hex 32
WA_INTERNAL_TOKEN=your_strong_random_token_here

# ── WS Auth ─────────────────────────────────────────────────
WS_JWT_SECRET=your_jwt_secret
ADMIN_TOKEN=your_admin_token

# ── Push Credentials ────────────────────────────────────────
PUSH_CREDENTIAL_SID=CRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Outbox Worker Tuning ────────────────────────────────────
OUTBOX_POLL_MS=2000
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RATE_ACCOUNT_MS=350
OUTBOX_RATE_GLOBAL_MS=20

# ── Redis (Voice VPS) ───────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Sentry (optional) ───────────────────────────────────────
SENTRY_DSN=

# ── Node ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
